# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sparquser:sparqpass@localhost:5432/roi_db
POSTGRES_USER=sparquser
POSTGRES_PASSWORD=sparqpass
POSTGRES_DB=roi_db

# ─── App ──────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_KEY
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CORS_ORIGINS=http://localhost:3000

# ─── HubSpot Private App ──────────────────────────────────────────────────────
# Get from: app.hubspot.com → Settings → Integrations → Private Apps → Create
# Copy the access token (starts with pat-na2-...)
# Leave blank to use mock data
HUBSPOT_ACCESS_TOKEN=

# ─── Salesforce (simplest method: username + password + security token) ───────
# Security token: Salesforce → Settings → My Personal Information → Reset Security Token
# Leave all blank to use mock data
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login   # use 'test' for sandbox orgs

# ─── Optional: Salesforce OAuth (if you set up a Connected App) ───────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/salesforce/callback

# ─── Optional: HubSpot OAuth (if you set up a Public App) ────────────────────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8000/api/v1/integrations/hubspot/callback
